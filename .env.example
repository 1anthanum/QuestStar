# ─── Mode 1: Shared deployment via alpha-proxy (recommended) ───
# When VITE_PROXY_URL is set, the app calls the proxy and never sees the real Anthropic key.
# Friends enter VITE_ACCESS_PASSWORD via the password gate (stored in localStorage after first entry).
VITE_PROXY_URL=
# Optional: pre-fill access password (skip the gate). Usually leave blank.
VITE_ACCESS_PASSWORD=

# ─── Mode 2: Local / personal use ───
# If VITE_PROXY_URL is empty, the app calls Anthropic directly with this key.
# Get from https://console.anthropic.com
VITE_CLAUDE_API_KEY=
